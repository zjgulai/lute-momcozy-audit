{
  "name": "lute-momcozy-audit",
  "version": "3.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build-history-site.mjs",
    "collect": "node scripts/collect.mjs",
    "collect:competitors": "node scripts/collect-competitors.mjs",
    "collect:summary": "node scripts/generate-collect-summary.mjs",
    "serve": "node scripts/serve.mjs",
    "monitor:uptime": "node scripts/uptime-monitor.mjs",
    "monitor:notify-summary": "node scripts/summarize-notify-failures.mjs",
    "audit:production-layout": "node scripts/audit-production-layout.mjs",
    "release:checklist": "node scripts/generate-release-checklist.mjs",
    "segment:aggregate": "node scripts/aggregate-segment-sessions.mjs --write",
    "owner-state:capture": "node scripts/owner-storage-state.mjs --capture",
    "owner-state:check": "node scripts/owner-storage-state.mjs --check",
    "owner-state:command": "node scripts/owner-storage-state.mjs --print-command",
    "test:allowlist": "node scripts/validate-public-data.mjs",
    "test:competitor-plan": "node scripts/validate-competitor-recollect-plan.mjs",
    "test:competitor-recollect-lib": "node --test tests/competitor-recollect.test.mjs",
    "test:competitor-snapshots": "node scripts/validate-competitor-snapshots.mjs",
    "test:release-contract": "node scripts/validate-release-contract.mjs",
    "test:insight-contract": "npm run build && node scripts/validate-insight-report-contract.mjs",
    "test:history-site-charts": "node --test tests/history-site-charts.test.mjs",
    "test:source-safety": "node scripts/safety-scan-source.mjs",
    "test:collection-config": "node scripts/validate-collection-config.mjs",
    "test:sessions": "node scripts/validate-sessions.mjs",
    "test:report-data-consistency": "node scripts/validate-report-data-consistency.mjs",
    "test:session-derived-metrics": "node --test tests/session-derived-metrics.test.mjs",
    "test:segment-sessions": "node scripts/validate-segment-sessions.mjs",
    "test:segment-aggregation": "node scripts/aggregate-segment-sessions.mjs --check && node --test tests/segment-session-aggregation.test.mjs",
    "test:owner-state": "node --test tests/owner-storage-state.test.mjs",
    "test:safety": "node scripts/safety-scan.mjs",
    "test:links": "node scripts/check-links.mjs",
    "test:uptime-monitor": "node --test tests/uptime-monitor.test.mjs",
    "test:uptime-cron": "node scripts/validate-uptime-cron.mjs --dry-run",
    "test:e2e": "npm run build && playwright test tests/e2e.spec.mjs",
    "test:a11y": "npm run build && playwright test tests/a11y.spec.mjs",
    "test": "npm run build && npm run test:release-contract && npm run test:history-site-charts && npm run test:insight-contract && npm run test:allowlist && npm run test:competitor-plan && npm run test:competitor-recollect-lib && npm run test:competitor-snapshots && npm run test:source-safety && npm run test:collection-config && npm run test:sessions && npm run test:report-data-consistency && npm run test:session-derived-metrics && npm run test:segment-sessions && npm run test:segment-aggregation && npm run test:owner-state && npm run test:safety && npm run test:links && npm run test:uptime-monitor && npm run test:uptime-cron && npm run test:e2e && npm run test:a11y",
    "test:release-parity": "node scripts/validate-release-parity.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.61.0",
    "ajv": "^8.17.1",
    "uplot": "^1.6.32"
  }
}
