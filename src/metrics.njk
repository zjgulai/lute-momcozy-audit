---
layout: layout.njk
permalink: /metrics/index.html
title: Metrics
description: Sanitized technical metrics with source and confidence.
---
<section class="hero compact">
  <p class="eyebrow">Measured, bounded, sourced</p>
  <h1>Technical metrics</h1>
  <p class="lede">Each observation carries its method and confidence. These are directional lab results, not real-user field data.</p>
</section>
<section aria-label="Technical observations">
  <div class="metric-grid">
    {% for item in audit.metrics %}
    <article class="metric-card">
      <p class="metric-label">{{ item.label }}</p>
      <p class="metric-value">{{ item.value }} <span>{{ item.unit }}</span></p>
      <p>{{ item.interpretation }}</p>
      <dl class="evidence">
        <div><dt>Source</dt><dd>{{ item.source }}</dd></div>
        <div><dt>Confidence</dt><dd><span class="confidence {{ item.confidence }}">{{ item.confidence }}</span></dd></div>
      </dl>
    </article>
    {% endfor %}
  </div>
</section>
<section aria-labelledby="glossary-title">
  <div class="section-heading"><p class="eyebrow">Shared language</p><h2 id="glossary-title">Glossary</h2></div>
  <div class="glossary-grid">
    {% for item in audit.glossary %}<article class="panel"><h3>{{ item.term }}</h3><p>{{ item.definition }}</p></article>{% endfor %}
  </div>
</section>

