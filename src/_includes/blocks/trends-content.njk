<link rel="stylesheet" href="/assets/uplot.min.css">

<section class="hero compact">
  <p class="eyebrow">基于 {{ sessions.length }} 个会话样本</p>
  <h1>趋势与健康度</h1>
  <p class="lede">每个点代表一次实验室采集，不追逐单个离散值，而关注方向性变化。</p>
  <aside class="public-cross-note" aria-label="趋势跨审计结论">
    <p class="eyebrow">审计边界</p>
    <p><strong>趋势用于发布前复核，不替代商业归因。</strong> 需明确区分手工采集与自动采集，趋势应触发技术复查，重点监控 JS 体积、DOM 节点、第三方失败与 LCP 可观测性。</p>
  </aside>
</section>

<section aria-labelledby="trends-charts-title">
  <div class="section-heading">
    <p class="eyebrow">核心指标随时间变化</p>
    <h2 id="trends-charts-title">会话级读取图</h2>
  </div>

  <div class="filter-row" role="search" aria-label="趋势筛选">
    <div class="filter-field">
      <label for="method-filter">采集类型</label>
      <select id="method-filter">
        <option value="all">全部</option>
        <option value="automated">仅自动化</option>
        <option value="manual">仅手工</option>
      </select>
    </div>
    <div class="filter-field">
      <label for="route-filter">路由范围</label>
      <select id="route-filter">
        <option value="all">全部路由</option>
      </select>
    </div>
  </div>

  <section aria-labelledby="latest-status-title">
    <div class="section-heading">
      <p class="eyebrow">最新自动化基线</p>
      <h2 id="latest-status-title">当前范围阈值状态</h2>
    </div>
    <div id="latest-threshold-grid" class="status-grid">
      <p class="status-empty">当前范围未检出自动采样。</p>
    </div>
  </section>

  <div class="trend-grid">
    <figure class="trend-card" aria-label="LCP 趋势">
      <figcaption>
        <span class="trend-label">LCP</span>
        <span class="trend-unit">秒 · 越低越好 · 良好 &lt; 2.5 s</span>
      </figcaption>
      <div id="chart-lcp" class="chart-wrap"></div>
    </figure>

    <figure class="trend-card" aria-label="FCP 趋势">
      <figcaption>
        <span class="trend-label">FCP</span>
        <span class="trend-unit">秒 · 越低越好 · 良好 &lt; 1.8 s</span>
      </figcaption>
      <div id="chart-fcp" class="chart-wrap"></div>
    </figure>

    <figure class="trend-card" aria-label="TTFB 趋势">
      <figcaption>
        <span class="trend-label">TTFB</span>
        <span class="trend-unit">毫秒 · 越低越好 · 良好 &lt; 800 ms</span>
      </figcaption>
      <div id="chart-ttfb" class="chart-wrap"></div>
    </figure>

    <figure class="trend-card" aria-label="CLS 趋势">
      <figcaption>
        <span class="trend-label">CLS</span>
        <span class="trend-unit">分数 · 越低越好 · 良好 &lt; 0.1</span>
      </figcaption>
      <div id="chart-cls" class="chart-wrap"></div>
    </figure>

    <figure class="trend-card" aria-label="第三方失败趋势">
      <figcaption>
        <span class="trend-label">第三方失败</span>
        <span class="trend-unit">次数 · 越低越好 · 目标 &lt; 10</span>
      </figcaption>
      <div id="chart-3p" class="chart-wrap"></div>
    </figure>

    <figure class="trend-card" aria-label="请求总量趋势">
      <figcaption>
        <span class="trend-label">请求总数</span>
        <span class="trend-unit">每次会话次数 · 仅自动采样</span>
      </figcaption>
      <div id="chart-requests" class="chart-wrap"></div>
    </figure>

    <figure class="trend-card" aria-label="JS 体积趋势">
      <figcaption>
        <span class="trend-label">JS 体积</span>
        <span class="trend-unit">KB · 越低越好 · 目标 &lt; 500 KB</span>
      </figcaption>
      <div id="chart-js" class="chart-wrap"></div>
    </figure>

    <figure class="trend-card" aria-label="DOM 节点趋势">
      <figcaption>
        <span class="trend-label">DOM 节点</span>
        <span class="trend-unit">数量 · 越低越好 · 阈值 &lt; 1,500</span>
      </figcaption>
      <div id="chart-dom" class="chart-wrap"></div>
    </figure>
  </div>
</section>

<section aria-labelledby="trends-table-title">
  <div class="section-heading">
    <p class="eyebrow">完整记录</p>
    <h2 id="trends-table-title">全部会话</h2>
  </div>
  <div class="table-wrap">
    <table class="sessions-table">
      <thead>
        <tr>
          <th scope="col">日期</th>
          <th scope="col">采集方式</th>
          <th scope="col">FCP (s)</th>
          <th scope="col">TTFB (ms)</th>
          <th scope="col">CLS</th>
          <th scope="col">TBT (ms)</th>
          <th scope="col">JS (KB)</th>
          <th scope="col">DOM</th>
          <th scope="col">请求数</th>
          <th scope="col">第三方失败(D/M)</th>
          <th scope="col">置信度</th>
        </tr>
      </thead>
      <tbody>
        {% for s in sessions | reverse %}
        {% if s.methodologyBreak %}
        <tr class="method-break-row">
          <td colspan="11" class="method-break-cell">
            <span class="method-break-label">⚠ 采样方法发生变化：该点起为首个自动化 Chromium 基线；手工采样仅作为历史参考，不可直接同比。</span>
          </td>
        </tr>
        {% endif %}
        <tr
          class="{{ 'row-manual' if not s.isAutomated else 'row-auto' }}{% if s.confidence == 'low' %} row-low-confidence{% endif %} session-row"
          data-method="{% if s.isAutomated %}automated{% else %}manual{% endif %}"
          data-route-ids="{{ s.routeIds | join(',') }}"
        >
          <td>{{ s.observedAt }}{% if not s.isAutomated %} <span class="method-badge">手工</span>{% endif %}</td>
          <td class="session-method"><span class="method-badge">{{ "自动化" if s.isAutomated else "手工" }}</span></td>
          <td class="num {% if s.metrics.fcp === null %}na{% elif s.metrics.fcp < 1.8 %}good{% elif s.metrics.fcp < 3 %}warn{% else %}bad{% endif %}">{{ s.metrics.fcp if s.metrics.fcp !== null else "N/A" }}</td>
          <td class="num {% if s.metrics.ttfb === null %}na{% elif s.metrics.ttfb < 800 %}good{% elif s.metrics.ttfb < 1800 %}warn{% else %}bad{% endif %}">{{ s.metrics.ttfb if s.metrics.ttfb !== null else "N/A" }}</td>
          <td class="num {% if s.metrics.cls < 0.1 %}good{% elif s.metrics.cls < 0.25 %}warn{% else %}bad{% endif %}">{{ s.metrics.cls }}</td>
          <td class="num {% if s.metrics.tbt === undefined or s.metrics.tbt === null %}na{% elif s.metrics.tbt < 200 %}good{% elif s.metrics.tbt < 600 %}warn{% else %}bad{% endif %}">{{ s.metrics.tbt if s.metrics.tbt !== undefined and s.metrics.tbt !== null else "—" }}</td>
          <td class="num {% if s.metrics.jsKb === undefined or s.metrics.jsKb === null %}na{% elif s.metrics.jsKb < 500 %}good{% elif s.metrics.jsKb < 1000 %}warn{% else %}bad{% endif %}">{{ s.metrics.jsKb if s.metrics.jsKb !== undefined and s.metrics.jsKb !== null else "—" }}</td>
          <td class="num {% if s.metrics.domNodes === undefined or s.metrics.domNodes === null %}na{% elif s.metrics.domNodes < 1500 %}good{% elif s.metrics.domNodes < 3000 %}warn{% else %}bad{% endif %}">{{ s.metrics.domNodes if s.metrics.domNodes !== undefined and s.metrics.domNodes !== null else "—" }}</td>
          <td class="num {% if s.metrics.totalRequests === undefined or s.metrics.totalRequests === null %}na{% elif s.metrics.totalRequests < 200 %}good{% elif s.metrics.totalRequests < 400 %}warn{% else %}bad{% endif %}">{{ s.metrics.totalRequests if s.metrics.totalRequests !== undefined and s.metrics.totalRequests !== null else "—" }}</td>
          <td class="num {% if s.metrics.thirdPartyFailures < 10 %}good{% elif s.metrics.thirdPartyFailures < 20 %}warn{% else %}bad{% endif %}">{{ s.metrics.thirdPartyFailures }}{% if s.mobile %} / {{ s.mobile.thirdPartyFailures }}{% endif %}</td>
          <td><span class="confidence {{ s.confidence }}">{{ s.confidence }}</span></td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
</section>

<section aria-labelledby="trends-delta-title">
  <div class="section-heading">
    <p class="eyebrow">相比上期</p>
    <h2 id="trends-delta-title">相邻会话变化</h2>
  </div>
  {% if sessions.length >= 2 %}
  {% set latest = sessions[sessions.length - 1] %}
  {% set prev = sessions[sessions.length - 2] %}
  <div class="delta-grid">
    {% set lcpDelta = latest.metrics.lcp - prev.metrics.lcp %}
    <article class="delta-card {% if latest.metrics.lcp == null or prev.metrics.lcp == null %}delta-neutral{% elif lcpDelta < 0 %}delta-good{% elif lcpDelta > 0 %}delta-bad{% else %}delta-neutral{% endif %}">
      <p class="delta-label">LCP</p>
      {% if latest.metrics.lcp == null or prev.metrics.lcp == null %}
      <p class="delta-value delta-na">N/A</p>
      <p class="delta-sub">实验室无可对比观测值，需补充真实用户路径</p>
      {% else %}
      <p class="delta-value">{{ lcpDelta | deltaSign }}{{ lcpDelta | toFixed(2) }} s</p>
      <p class="delta-sub">{{ latest.metrics.lcp }} s（当前）· {{ prev.metrics.lcp }} s（上次）</p>
      {% endif %}
    </article>
    {% set fcpDelta = latest.metrics.fcp - prev.metrics.fcp %}
    <article class="delta-card {% if latest.metrics.fcp == null or prev.metrics.fcp == null %}delta-neutral{% elif fcpDelta < 0 %}delta-good{% elif fcpDelta > 0 %}delta-bad{% else %}delta-neutral{% endif %}">
      <p class="delta-label">FCP</p>
      {% if latest.metrics.fcp == null or prev.metrics.fcp == null %}
      <p class="delta-value delta-na">N/A</p>
      <p class="delta-sub">任一会话缺失 FCP</p>
      {% else %}
      <p class="delta-value">{{ fcpDelta | deltaSign }}{{ fcpDelta | toFixed(2) }} s</p>
      <p class="delta-sub">{{ latest.metrics.fcp }} s（当前）· {{ prev.metrics.fcp }} s（上次）</p>
      {% endif %}
    </article>
    {% set ttfbDelta = latest.metrics.ttfb - prev.metrics.ttfb %}
    <article class="delta-card {% if latest.metrics.ttfb == null or prev.metrics.ttfb == null %}delta-neutral{% elif ttfbDelta < 0 %}delta-good{% elif ttfbDelta > 0 %}delta-bad{% else %}delta-neutral{% endif %}">
      <p class="delta-label">TTFB</p>
      {% if latest.metrics.ttfb == null or prev.metrics.ttfb == null %}
      <p class="delta-value delta-na">N/A</p>
      <p class="delta-sub">任一会话缺失 TTFB</p>
      {% else %}
      <p class="delta-value">{{ ttfbDelta | deltaSign }}{{ ttfbDelta | toFixed(0) }} ms</p>
      <p class="delta-sub">{{ latest.metrics.ttfb }} ms（当前）· {{ prev.metrics.ttfb }} ms（上次）</p>
      {% endif %}
    </article>
    {% set clsDelta = latest.metrics.cls - prev.metrics.cls %}
    <article class="delta-card {% if clsDelta < 0 %}delta-good{% elif clsDelta > 0 %}delta-bad{% else %}delta-neutral{% endif %}">
      <p class="delta-label">CLS</p>
      <p class="delta-value">{{ clsDelta | deltaSign }}{{ clsDelta | toFixed(4) }}</p>
      <p class="delta-sub">{{ latest.metrics.cls }}（当前）· {{ prev.metrics.cls }}（上次）</p>
    </article>
    {% if latest.metrics.thirdPartyFailures !== undefined and prev.metrics.thirdPartyFailures !== undefined %}
    {% set failDelta = latest.metrics.thirdPartyFailures - prev.metrics.thirdPartyFailures %}
    <article class="delta-card {% if failDelta < 0 %}delta-good{% elif failDelta > 0 %}delta-bad{% else %}delta-neutral{% endif %}">
      <p class="delta-label">第三方失败</p>
      <p class="delta-value">{{ failDelta | deltaSign }}{{ failDelta }}</p>
      <p class="delta-sub">{{ latest.metrics.thirdPartyFailures }}（当前）· {{ prev.metrics.thirdPartyFailures }}（上次）</p>
    </article>
    {% endif %}
  </div>
  {% else %}
  <p class="lede">至少需要 2 个样本才会展示变化值。</p>
  {% endif %}
</section>

<script id="sessions-data" type="application/json">{{ sessions | jsonStringify | safe }}</script>
<script src="/assets/uplot.min.js"></script>
<script src="/assets/trends-charts.js"></script>
