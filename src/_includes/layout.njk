<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <meta name="description" content="{{ description }}">
    <title>{{ title }} · Lute Technical Audit</title>
    <!-- Open Graph -->
    <meta property="og:type"        content="website">
    <meta property="og:title"       content="{{ title }} · Lute Technical Audit">
    <meta property="og:description" content="{{ description }}">
    <meta property="og:site_name"   content="Lute Technical Audit">
    <!-- Favicon: inline SVG data URI — zero extra request -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='6' fill='%2316684d'/%3E%3Ctext x='16' y='22' font-family='Georgia,serif' font-size='18' font-weight='700' fill='white' text-anchor='middle'%3EL%3C/text%3E%3C/svg%3E">
    <link rel="stylesheet" href="/assets/site.css">
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <header class="site-header">
      <a class="brand" href="/">Lute <span>Technical Audit</span></a>
      <nav aria-label="Primary">
        <a href="/" {% if page.url == "/" %}aria-current="page"{% endif %}>Overview</a>
        <a href="/metrics/" {% if page.url == "/metrics/" %}aria-current="page"{% endif %}>Metrics</a>
        <a href="/forensics/" {% if page.url == "/forensics/" %}aria-current="page"{% endif %}>Forensics</a>
        <a href="/trends/" {% if page.url == "/trends/" %}aria-current="page"{% endif %}>Trends</a>
      </nav>
    </header>
    <main id="main">{{ content | safe }}</main>
    <footer>
      <p>{{ audit.meta.publication }} · Observed {{ audit.meta.observedAt }}</p>
      <p>Technical observations only. No private business data is published.</p>
    </footer>
  </body>
</html>

