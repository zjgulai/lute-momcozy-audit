{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["sessionId", "observedAt", "collectedBy", "targetUrl", "metrics", "confidence"],
  "properties": {
    "sessionId": {
      "type": "string",
      "pattern": "^session-\\d{4}-\\d{2}-\\d{2}$"
    },
    "observedAt": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "collectedBy":  {"type": "string"},
    "methodologyVersion": {"type": "string"},
    "targetUrl":    {"type": "string"},
    "confidence":   {"enum": ["high", "medium", "low"]},
    "notes":        {"type": "string"},
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lcp", "fcp", "ttfb", "cls"],
      "properties": {
        "lcp":                {"type": ["number", "null"]},
        "lcpNullReason":      {"type": "string"},
        "fcp":                {"type": ["number", "null"]},
        "ttfb":               {"type": ["number", "null"]},
        "cls":                {"type": "number"},
        "tbt":                {"type": ["integer", "null"]},
        "domNodes":           {"type": ["integer", "null"]},
        "longTasks":          {"type": "integer", "minimum": 0},
        "totalRequests":      {"type": ["integer", "null"]},
        "jsKb":               {"type": ["integer", "null"]},
        "thirdPartyFailures": {"type": "integer", "minimum": 0}
      }
    },
    "mobile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lcp":                {"type": ["number", "null"]},
        "lcpNullReason":      {"type": "string"},
        "fcp":                {"type": ["number", "null"]},
        "ttfb":               {"type": ["number", "null"]},
        "cls":                {"type": "number"},
        "tbt":                {"type": ["integer", "null"]},
        "thirdPartyFailures": {"type": "integer", "minimum": 0}
      }
    },
    "routes": {
      "type": "array",
      "items": {"$ref": "#/$defs/route"}
    },
    "observations": {
      "type": "array",
      "items": {"$ref": "#/$defs/observation"}
    }
  },
  "$defs": {
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routeId", "label", "path", "primary", "viewports"],
      "properties": {
        "routeId": {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "label": {"type": "string"},
        "path": {"type": "string", "pattern": "^/"},
        "primary": {"type": "boolean"},
        "viewports": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/viewport"}
        }
      }
    },
    "viewport": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "width", "height", "metrics"],
      "properties": {
        "label": {"enum": ["desktop", "mobile"]},
        "width": {"type": "integer", "minimum": 1},
        "height": {"type": "integer", "minimum": 1},
        "metrics": {"$ref": "#/$defs/routeMetrics"}
      }
    },
    "routeMetrics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lcp",
        "fcp",
        "ttfb",
        "cls",
        "tbt",
        "domNodes",
        "longTasks",
        "totalRequests",
        "transferKb",
        "jsKb",
        "thirdPartyFailures",
        "consoleErrors",
        "pageErrors",
        "loadEventMs",
        "scriptTags",
        "iframeCount",
        "imagesTotal",
        "imagesWebp",
        "imagesWebpPct",
        "missingAlt",
        "missingSrcset",
        "aboveFoldImages",
        "aboveFoldLazyImages"
      ],
      "properties": {
        "lcp": {"type": ["number", "null"]},
        "lcpNullReason": {"type": "string"},
        "fcp": {"type": ["number", "null"]},
        "ttfb": {"type": ["number", "null"]},
        "cls": {"type": "number"},
        "tbt": {"type": ["integer", "null"]},
        "domNodes": {"type": ["integer", "null"]},
        "longTasks": {"type": "integer", "minimum": 0},
        "totalRequests": {"type": ["integer", "null"]},
        "transferKb": {"type": ["integer", "null"]},
        "jsKb": {"type": ["integer", "null"]},
        "thirdPartyFailures": {"type": "integer", "minimum": 0},
        "consoleErrors": {"type": "integer", "minimum": 0},
        "pageErrors": {"type": "integer", "minimum": 0},
        "loadEventMs": {"type": ["integer", "null"]},
        "scriptTags": {"type": "integer", "minimum": 0},
        "iframeCount": {"type": "integer", "minimum": 0},
        "imagesTotal": {"type": "integer", "minimum": 0},
        "imagesWebp": {"type": "integer", "minimum": 0},
        "imagesWebpPct": {"type": "number", "minimum": 0},
        "missingAlt": {"type": "integer", "minimum": 0},
        "missingSrcset": {"type": "integer", "minimum": 0},
        "aboveFoldImages": {"type": "integer", "minimum": 0},
        "aboveFoldLazyImages": {"type": "integer", "minimum": 0}
      }
    },
    "observation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routeId", "viewport", "metrics"],
      "properties": {
        "routeId":   {"type": "string", "pattern": "^[a-z0-9-]+$"},
        "routeLabel": {"type": "string"},
        "routePath":  {"type": "string"},
        "viewport":  {"enum": ["desktop", "mobile"]},
        "metrics":   {"$ref": "#/$defs/routeMetrics"}
      }
    }
  }
}
