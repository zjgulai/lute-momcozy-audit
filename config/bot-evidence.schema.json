{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lute.local/schemas/bot-evidence.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "status",
    "domain",
    "updatedAt",
    "evidenceWindow",
    "requiredSources",
    "requiredSegments",
    "diagnosticQuestions",
    "acceptanceGates",
    "metrics"
  ],
  "properties": {
    "schemaVersion": {"const": "bot-evidence-v1"},
    "status": {"enum": ["missing", "measured", "blocked"]},
    "domain": {"const": "www.momcozy.com"},
    "updatedAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "summary": {"type": "string", "minLength": 1},
    "evidenceWindow": {
      "type": "object",
      "additionalProperties": false,
      "required": ["current", "baseline", "grain"],
      "properties": {
        "current": {"type": "string", "minLength": 1},
        "baseline": {"type": "string", "minLength": 1},
        "grain": {"enum": ["session", "visitor", "request"]}
      }
    },
    "requiredSources": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "label", "state", "requiredFields"],
        "properties": {
          "id": {"enum": ["owner_analytics", "bot_log", "human_bot_dimension"]},
          "label": {"type": "string", "minLength": 1},
          "state": {"enum": ["missing", "ready", "blocked"]},
          "note": {"type": "string"},
          "requiredFields": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          }
        }
      }
    },
    "requiredSegments": {
      "type": "array",
      "minItems": 4,
      "items": {"enum": ["human", "bot", "crawler", "unknown"]}
    },
    "diagnosticQuestions": {
      "type": "array",
      "minItems": 3,
      "items": {"type": "string", "minLength": 1}
    },
    "acceptanceGates": {
      "type": "array",
      "minItems": 4,
      "items": {"type": "string", "minLength": 1}
    },
    "metrics": {
      "anyOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["totalSessions", "segments"],
          "properties": {
            "totalSessions": {"type": "integer", "minimum": 1},
            "segments": {
              "type": "array",
              "minItems": 4,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "segment",
                  "sessions",
                  "conversionRate",
                  "bounceRate",
                  "avgStaySec"
                ],
                "properties": {
                  "segment": {"enum": ["human", "bot", "crawler", "unknown"]},
                  "sessions": {"type": "integer", "minimum": 0},
                  "conversionRate": {"type": "number", "minimum": 0, "maximum": 1},
                  "bounceRate": {"type": "number", "minimum": 0, "maximum": 1},
                  "avgStaySec": {"type": "number", "minimum": 0}
                }
              }
            }
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "measured"}}},
      "then": {"not": {"properties": {"metrics": {"type": "null"}}}}
    },
    {
      "if": {"properties": {"status": {"enum": ["missing", "blocked"]}}},
      "then": {"properties": {"metrics": {"type": "null"}}}
    }
  ]
}
